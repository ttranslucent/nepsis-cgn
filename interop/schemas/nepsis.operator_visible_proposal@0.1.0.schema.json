{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nepsis.local/schemas/nepsis.operator_visible_proposal@0.1.0.schema.json",
  "title": "Nepsis operator-visible consequential proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "alternatives_summary",
    "evidence_refs",
    "hazards_summary",
    "operator_visible_proposal_schema_version",
    "proposal_text",
    "rationale_text",
    "requested_change"
  ],
  "properties": {
    "alternatives_summary": { "$ref": "#/$defs/nonEmptyString" },
    "evidence_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "hazards_summary": { "$ref": "#/$defs/nonEmptyString" },
    "operator_visible_proposal_schema_version": {
      "const": "nepsis.operator_visible_proposal@0.1.0"
    },
    "proposal_text": { "$ref": "#/$defs/nonEmptyString" },
    "rationale_text": { "$ref": "#/$defs/nonEmptyString" },
    "requested_change": {
      "type": "object",
      "minProperties": 1
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 }
  }
}

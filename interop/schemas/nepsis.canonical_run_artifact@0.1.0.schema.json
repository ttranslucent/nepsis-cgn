{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nepsis.local/schemas/nepsis.canonical_run_artifact@0.1.0.schema.json",
  "title": "Nepsis canonical content-addressed run artifact row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact",
    "artifact_hash",
    "artifact_schema_version",
    "canonical_run_artifact_schema_version",
    "created_sequence",
    "roles",
    "run_id"
  ],
  "properties": {
    "artifact": { "type": "object", "minProperties": 1 },
    "artifact_hash": { "$ref": "#/$defs/sha256" },
    "artifact_schema_version": { "$ref": "#/$defs/fullVersion" },
    "canonical_run_artifact_schema_version": {
      "const": "nepsis.canonical_run_artifact@0.1.0"
    },
    "created_sequence": { "type": "integer", "minimum": 0 },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "run_id": { "$ref": "#/$defs/nonEmptyString" }
  },
  "$defs": {
    "fullVersion": {
      "type": "string",
      "pattern": "^nepsis\\.[a-z0-9_.-]+@[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}

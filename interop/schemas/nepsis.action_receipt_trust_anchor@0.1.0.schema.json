{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nepsis.local/schemas/nepsis.action_receipt_trust_anchor@0.1.0.schema.json",
  "title": "Nepsis Ed25519 action receipt trust anchor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_receipt_trust_anchor_schema_version",
    "activated_at",
    "algorithm",
    "key_id",
    "public_key"
  ],
  "properties": {
    "action_receipt_trust_anchor_schema_version": {
      "const": "nepsis.action_receipt_trust_anchor@0.1.0"
    },
    "activated_at": { "$ref": "#/$defs/timestamp" },
    "algorithm": { "const": "ed25519" },
    "key_id": { "type": "string", "pattern": "^ed25519:[0-9a-f]{64}$" },
    "public_key": { "type": "string", "pattern": "^[A-Za-z0-9_-]{43}$" },
    "revoked_at": { "$ref": "#/$defs/timestamp" }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    }
  }
}

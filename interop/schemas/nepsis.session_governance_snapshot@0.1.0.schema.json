{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nepsis.local/schemas/nepsis.session_governance_snapshot@0.1.0.schema.json",
  "title": "Nepsis immutable session governance snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "constitution_hash",
    "constitution_version",
    "created_at",
    "created_by",
    "effective_policy",
    "effective_policy_hash",
    "governance_comparator_policy_hash",
    "governance_comparator_policy_version",
    "operator_governance_profile_hash",
    "profile_id",
    "profile_revision",
    "run_id",
    "session_governance_snapshot_schema_version",
    "snapshot_id",
    "source_annotations",
    "validated_overrides"
  ],
  "properties": {
    "constitution_hash": { "$ref": "#/$defs/sha256" },
    "constitution_version": { "$ref": "#/$defs/fullVersion" },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "created_by": {
      "type": "string",
      "pattern": "^validator:[a-z0-9._@-]+$"
    },
    "effective_policy": { "type": "object", "minProperties": 1 },
    "effective_policy_hash": { "$ref": "#/$defs/sha256" },
    "fork_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fork_reason",
        "forked_from_run_id",
        "inherited_evidence_root_hashes",
        "parent_head_event_hash",
        "policy_diff_artifact_hash"
      ],
      "properties": {
        "fork_reason": { "$ref": "#/$defs/nonEmptyString" },
        "forked_from_run_id": { "$ref": "#/$defs/nonEmptyString" },
        "inherited_evidence_root_hashes": {
          "type": "array",
          "items": { "$ref": "#/$defs/sha256" },
          "uniqueItems": true
        },
        "parent_head_event_hash": { "$ref": "#/$defs/sha256" },
        "policy_diff_artifact_hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "governance_comparator_policy_hash": { "$ref": "#/$defs/sha256" },
    "governance_comparator_policy_version": {
      "const": "nepsis.governance_comparator_policy@0.1.0"
    },
    "operator_governance_profile_hash": { "$ref": "#/$defs/sha256" },
    "profile_id": { "$ref": "#/$defs/nonEmptyString" },
    "profile_revision": { "type": "integer", "minimum": 1 },
    "run_id": { "$ref": "#/$defs/nonEmptyString" },
    "session_governance_snapshot_schema_version": {
      "const": "nepsis.session_governance_snapshot@0.1.0"
    },
    "snapshot_id": { "$ref": "#/$defs/nonEmptyString" },
    "source_annotations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field_path", "source", "source_hash"],
        "properties": {
          "field_path": { "$ref": "#/$defs/nonEmptyString" },
          "source": {
            "enum": ["system_locked", "operator_profile", "session_override"]
          },
          "source_hash": { "$ref": "#/$defs/sha256" }
        }
      },
      "uniqueItems": true
    },
    "validated_overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "comparison",
          "created_at",
          "field_path",
          "operator_id",
          "override_id",
          "proposed_value_artifact_hash",
          "rationale"
        ],
        "properties": {
          "comparison": { "enum": ["equal", "tighter", "incomparable"] },
          "created_at": { "$ref": "#/$defs/timestamp" },
          "field_path": { "$ref": "#/$defs/nonEmptyString" },
          "operator_id": { "type": "string", "pattern": "^operator:[a-z0-9._@-]+$" },
          "override_id": { "$ref": "#/$defs/nonEmptyString" },
          "proposed_value_artifact_hash": { "$ref": "#/$defs/sha256" },
          "rationale": { "$ref": "#/$defs/nonEmptyString" }
        }
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "fullVersion": {
      "type": "string",
      "pattern": "^nepsis\\.[a-z0-9_.-]+@[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    }
  }
}

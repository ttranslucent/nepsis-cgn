{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nepsis.local/schemas/nepsis.action_receipt@0.1.0.schema.json",
  "title": "Nepsis canonical run action receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_receipt_schema_version",
    "actor_id",
    "advanced_head",
    "artifact_hashes",
    "capability",
    "capability_id",
    "effective_policy_hash",
    "expected_head_event_hash",
    "expected_head_sequence",
    "idempotency_key",
    "intent_hash",
    "issued_at",
    "outcome",
    "packet_projection_hash",
    "policy_bindings",
    "postcondition",
    "postcondition_hash",
    "prior_head_event_hash",
    "prior_head_sequence",
    "receipt_id",
    "request_hash",
    "resulting_head_event_hash",
    "resulting_head_sequence",
    "run_id",
    "operator_governance_profile_hash",
    "provenance_class",
    "session_governance_snapshot_hash",
    "signature",
    "signed_at",
    "trusted_adapter_intent_id",
    "validator_policy_hash",
    "validator_policy_version",
    "verification_level"
  ],
  "properties": {
    "action_receipt_schema_version": {
      "const": "nepsis.action_receipt@0.1.0"
    },
    "actor_id": {
      "type": "string",
      "pattern": "^(model|operator|validator|system):[a-z0-9._@-]+$"
    },
    "advanced_head": { "type": "boolean" },
    "artifact_hashes": { "$ref": "#/$defs/hashArray" },
    "capability": {
      "enum": [
        "create_run",
        "fork_run",
        "submit_model_candidate",
        "submit_operator_disposition",
        "release_still",
        "perform_zeroback",
        "request_decision_commit"
      ]
    },
    "capability_id": { "$ref": "#/$defs/nonEmptyString" },
    "context_manifest_hash": { "$ref": "#/$defs/sha256" },
    "effective_policy_hash": { "$ref": "#/$defs/sha256" },
    "event_hash": { "$ref": "#/$defs/sha256" },
    "expected_head_event_hash": { "$ref": "#/$defs/sha256" },
    "expected_head_sequence": { "type": "integer", "minimum": 0 },
    "idempotency_key": { "$ref": "#/$defs/nonEmptyString" },
    "intent_hash": { "$ref": "#/$defs/sha256" },
    "issued_at": { "$ref": "#/$defs/timestamp" },
    "outcome": {
      "enum": [
        "candidate_recorded",
        "committed",
        "refused",
        "stale_head",
        "invalid_request"
      ]
    },
    "packet_projection_hash": { "$ref": "#/$defs/sha256" },
    "policy_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["policy_hash", "policy_id", "policy_version"],
        "properties": {
          "policy_hash": { "$ref": "#/$defs/sha256" },
          "policy_id": { "$ref": "#/$defs/nonEmptyString" },
          "policy_version": { "$ref": "#/$defs/fullVersion" }
        }
      },
      "uniqueItems": true
    },
    "postcondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active_hold", "governance_status", "packet_projection_hash", "phase"],
      "properties": {
        "active_hold": { "type": "boolean" },
        "governance_status": { "$ref": "#/$defs/nonEmptyString" },
        "packet_projection_hash": { "$ref": "#/$defs/sha256" },
        "phase": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "postcondition_hash": { "$ref": "#/$defs/sha256" },
    "prior_head_event_hash": { "$ref": "#/$defs/sha256" },
    "prior_head_sequence": { "type": "integer", "minimum": 0 },
    "receipt_id": { "$ref": "#/$defs/nonEmptyString" },
    "request_hash": { "$ref": "#/$defs/sha256" },
    "resulting_head_event_hash": { "$ref": "#/$defs/sha256" },
    "resulting_head_sequence": { "type": "integer", "minimum": 0 },
    "run_id": { "$ref": "#/$defs/nonEmptyString" },
    "operator_governance_profile_hash": { "$ref": "#/$defs/sha256" },
    "provenance_class": {
      "enum": ["model", "operator", "validator", "system"]
    },
    "reason_code": { "$ref": "#/$defs/nonEmptyString" },
    "detail": { "$ref": "#/$defs/nonEmptyString" },
    "session_governance_snapshot_hash": { "$ref": "#/$defs/sha256" },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "value"],
      "properties": {
        "algorithm": { "const": "ed25519" },
        "key_id": { "$ref": "#/$defs/nonEmptyString" },
        "value": { "type": "string", "pattern": "^[A-Za-z0-9_-]{86}$" }
      }
    },
    "signed_at": { "$ref": "#/$defs/timestamp" },
    "trusted_adapter_intent_id": { "$ref": "#/$defs/nonEmptyString" },
    "validator_policy_hash": { "$ref": "#/$defs/sha256" },
    "validator_policy_version": { "$ref": "#/$defs/nonEmptyString" },
    "verification_level": { "const": "writer_post_commit_reread" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "enum": ["candidate_recorded", "committed", "refused"]
          }
        },
        "required": ["outcome"]
      },
      "then": { "required": ["event_hash"] }
    },
    {
      "if": {
        "properties": { "capability": { "const": "submit_model_candidate" } },
        "required": ["capability"]
      },
      "then": { "required": ["context_manifest_hash"] }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "enum": ["refused", "stale_head", "invalid_request"]
          }
        },
        "required": ["outcome"]
      },
      "then": { "required": ["detail", "reason_code"] }
    },
    {
      "if": {
        "properties": {
          "outcome": { "enum": ["stale_head", "invalid_request"] }
        },
        "required": ["outcome"]
      },
      "then": { "properties": { "advanced_head": { "const": false } } }
    }
  ],
  "$defs": {
    "fullVersion": {
      "type": "string",
      "pattern": "^nepsis\\.[a-z0-9_.-]+@[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "hashArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/sha256" },
      "uniqueItems": true
    },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    }
  }
}

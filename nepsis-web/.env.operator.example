# Private operator deployment
# Use this only for a separate authenticated operator environment, not the
# frozen public /mvp site.

NEXT_PUBLIC_NEPSIS_PUBLIC_SITE=false
NEPSIS_DEPLOYMENT_MODE=operator
NEXT_PUBLIC_NEPSIS_OPERATOR_SITE=true
NEPSIS_LIVE_OPERATOR_ENABLED=true

NEPSIS_API_BASE_URL=https://nepsis-cgn-api.vercel.app
NEPSIS_API_TOKEN=replace-with-vercel-api-private-backend-token
NEPSIS_ENGINE_ALLOW_ANON=false
NEPSIS_V3_PACKET_SEAL_SECRET=replace-with-long-random-v3-packet-seal-secret
NEPSIS_OPERATOR_PACKET_SEAL_SECRET=replace-with-long-random-operator-packet-seal-secret

# Real login, not local preview-code mode.
NEPSIS_AUTH_SECRET=replace-with-long-random-operator-cookie-secret
NEPSIS_AUTH_ALLOWED_EMAILS=operator@example.com
NEPSIS_AUTH_SESSION_REVOKE_BEFORE=
RESEND_API_KEY=replace-with-resend-api-key
NEPSIS_AUTH_FROM_EMAIL=Nepsis Operator <login@operator.your-domain.test>
NEPSIS_AUTH_ALLOW_CODE_PREVIEW=false

# Live model routes are private, authenticated, and server-side only.
NEPSIS_MODEL_ROUTES_ENABLED=true
OPENAI_API_KEY=replace-with-server-side-openai-key
NEPSIS_OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_URL=https://api.openai.com/v1/responses
NEPSIS_OPERATOR_PROPOSAL_RECEIPT_SECRET=replace-with-long-random-proposal-receipt-secret
NEPSIS_OPERATOR_PROPOSAL_RECEIPT_KEY_ID=default

# Optional hosted MCP tool-call capability hashes. Store hashes only.
NEPSIS_MCP_CAPABILITY_TOKEN_HASHES=operator-1:replace-with-sha256-of-capability-token

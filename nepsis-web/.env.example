# Nepsis web app local development environment
# Copy to .env.local for local development only.
# For deployments, start from .env.public.example or .env.operator.example.

# Required in production: public base URL for the Nepsis API behind /api/engine/*
NEPSIS_API_BASE_URL=http://127.0.0.1:8787

# Optional: bearer token forwarded from the web proxy to the Nepsis API
NEPSIS_API_TOKEN=

# Optional: hash metadata for hosted MCP capability tokens.
# Store token-id:sha256(token) entries only; never put provider API keys here.
NEPSIS_MCP_CAPABILITY_TOKEN_HASHES=

# Optional: allow engine session controls without browser login.
# This is for local demos only and is ignored in public-site mode.
NEPSIS_ENGINE_ALLOW_ANON=false

# Optional: render the deployment as a public site in local/dev checks.
# Production builds also behave as public site mode by default.
NEXT_PUBLIC_NEPSIS_PUBLIC_SITE=false

# Optional private operator deployment mode.
# Leave these disabled for the public demo deployment.
NEPSIS_DEPLOYMENT_MODE=
NEXT_PUBLIC_NEPSIS_OPERATOR_SITE=false
NEPSIS_LIVE_OPERATOR_ENABLED=false

# Required in production: random secret used to sign login and session cookies
NEPSIS_AUTH_SECRET=replace-with-a-long-random-secret

# Required for operator login: exact email addresses allowed to request OTP login.
# Separate multiple addresses with commas or spaces.
NEPSIS_AUTH_ALLOWED_EMAILS=

# Optional: ISO timestamp used to invalidate older signed browser sessions globally.
NEPSIS_AUTH_SESSION_REVOKE_BEFORE=

# Required for emailed passwordless login codes. Leave blank for local preview-code login.
RESEND_API_KEY=
NEPSIS_AUTH_FROM_EMAIL=

# Optional for local-only testing: show the one-time login code in the UI when email is unavailable.
# This is ignored in public-site mode.
NEPSIS_AUTH_ALLOW_CODE_PREVIEW=false

# Optional server-side OpenAI defaults for playground/model sandbox routes.
# Model routes stay disabled in public-site mode even if NEPSIS_MODEL_ROUTES_ENABLED=true.
NEPSIS_MODEL_ROUTES_ENABLED=false
OPENAI_API_KEY=
NEPSIS_OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_URL=https://api.openai.com/v1/responses

# Optional local proto-puzzle overrides
# Leave NEPSIS_PYTHON blank to auto-detect ../.venv/bin/python in local dev.
NEPSIS_PYTHON=
NEPSIS_PROJECT_ROOT=..
NEPSIS_PROTO_PUZZLE_CLI=nepsis_cgn.cli.proto_puzzle_cli

# Nepsis web app environment
# Copy to .env.local for local development or set these in Vercel project settings.

# Required in production: public base URL for the Nepsis API behind /api/engine/*
NEPSIS_API_BASE_URL=http://127.0.0.1:8787

# Optional: bearer token forwarded from the web proxy to the Nepsis API
NEPSIS_API_TOKEN=

# Optional: allow engine session controls without browser login. Use only for local demos.
NEPSIS_ENGINE_ALLOW_ANON=false

# Required in production: random secret used to sign login and session cookies
NEPSIS_AUTH_SECRET=replace-with-a-long-random-secret

# Required for emailed passwordless login codes
RESEND_API_KEY=re_xxxxxxxxxxxxx
NEPSIS_AUTH_FROM_EMAIL=NepsisCGN <auth@example.com>

# Optional for preview-only testing: show the one-time login code in the UI when email is unavailable
NEPSIS_AUTH_ALLOW_CODE_PREVIEW=false

# Optional server-side OpenAI defaults for playground/model sandbox routes
OPENAI_API_KEY=your_openai_api_key_here
NEPSIS_OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_URL=https://api.openai.com/v1/responses

# Optional local proto-puzzle overrides
NEPSIS_PYTHON=python3
NEPSIS_PROJECT_ROOT=..
NEPSIS_PROTO_PUZZLE_CLI=nepsis_cgn.cli.proto_puzzle_cli

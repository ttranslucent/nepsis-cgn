# Frozen public /mvp deployment
# Use this for the public Vercel site. It keeps the MVP deterministic,
# login-gated operator surfaces closed, and model routes disabled.

NEXT_PUBLIC_NEPSIS_PUBLIC_SITE=true
NEXT_PUBLIC_NEPSIS_OPERATOR_SITE=false
NEPSIS_DEPLOYMENT_MODE=
NEPSIS_LIVE_OPERATOR_ENABLED=false

# Optional but recommended when the FastAPI backend is deployed.
# If omitted, /api/engine/mvp serves bundled frozen MVP packets.
NEPSIS_API_BASE_URL=https://nepsis-cgn-api.vercel.app
NEPSIS_API_TOKEN=replace-with-vercel-api-web-proxy-token

# Cookie signing for closed auth/session routes. Public /mvp does not require login.
NEPSIS_AUTH_SECRET=replace-with-long-random-public-cookie-secret
NEPSIS_AUTH_ALLOWED_EMAILS=
NEPSIS_AUTH_SESSION_REVOKE_BEFORE=
RESEND_API_KEY=
NEPSIS_AUTH_FROM_EMAIL=
NEPSIS_AUTH_ALLOW_CODE_PREVIEW=false
NEPSIS_ENGINE_ALLOW_ANON=false

# The public site must stay model-free.
NEPSIS_MODEL_ROUTES_ENABLED=false
OPENAI_API_KEY=
NEPSIS_OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_URL=https://api.openai.com/v1/responses
NEPSIS_OPERATOR_PROPOSAL_RECEIPT_SECRET=
NEPSIS_OPERATOR_PROPOSAL_RECEIPT_KEY_ID=default

# Optional hosted MCP tool-call capability hashes. Store hashes only.
NEPSIS_MCP_CAPABILITY_TOKEN_HASHES=
